{
    "name": "kelps/blog",
    "description": "Kelps Blog - Plataforma de blog social com PHP e PostgreSQL",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.7",
        "phpmailer/phpmailer": "^6.9",
        "erusev/parsedown": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:${PORT:-8080} -t public",
        "test": "phpunit --testdox"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
