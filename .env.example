# ================================================================
# Kelps Blog — Variáveis de ambiente
# Copie para .env e preencha os valores (nunca commite .env!)
# ================================================================

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
APP_ENV=production          # production | development
APP_DEBUG=false
APP_URL=https://seu-app.railway.app

# ------------------------------------------------------------------
# Banco de dados PostgreSQL
# Railway preenche automaticamente as variáveis PGHOST, PGPORT, etc.
# Para conexão externa use DB_HOST, DB_PORT, etc.
# ------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kelps_blog
DB_USER=postgres
DB_PASSWORD=senha_segura

# Variáveis automáticas do Railway (não precisa preencher em produção):
# PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD, DATABASE_URL

# ------------------------------------------------------------------
# E-mail (PHPMailer / SMTP)
# ------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu@email.com
MAIL_PASSWORD=app_password
MAIL_FROM_ADDRESS=noreply@seudominio.com
MAIL_FROM_NAME="Kelps Blog"
MAIL_ENCRYPTION=tls

# ------------------------------------------------------------------
# Upload de imagens
# ------------------------------------------------------------------
UPLOAD_MAX_SIZE=5242880     # 5 MB em bytes
